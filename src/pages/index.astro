    background: var(--blue);
    color: white;
    font-size: 0.86rem;
    font-weight: 750;
    white-space: nowrap;
  }

  .mobile-section-menu {
    display: none;
  }

  .hero {
    padding: 5.75rem 0 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1.25rem;
  }

  .eyebrow {
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 750;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .lead {
    max-width: 650px;
    font-size: 1.12rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.25rem;
  }

  .button,
  button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.85rem 1.1rem;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 650;
  }

  .primary,
  button {
    background: var(--blue);
    color: white;
    border: 1px solid var(--blue);
  }

  .secondary {
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--border);
    color: var(--text);
  }

  button:disabled {
    cursor: not-allowed;
    opacity: 0.75;
  }

  .trust-row,
  .about-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.5rem;
  }

  .trust-row span,
  .about-points span {
    display: inline-flex;
    padding: 0.45rem 0.65rem;
    border-radius: 999px;
    background: var(--blue-soft);
    color: var(--blue-dark);
    font-size: 0.85rem;
    font-weight: 650;
  }

  .phone-showcase {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 1rem;
    min-height: 680px;
  }

  .phone-frame {
    position: relative;
    width: min(100%, 360px);
    height: 690px;
    padding: 0.9rem;
    border-radius: 3rem;
    background:
      linear-gradient(145deg, #111827, #020617),
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 12rem);
    box-shadow:
      0 30px 80px rgba(16, 24, 40, 0.26),
      inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .phone-speaker {
    position: absolute;
    top: 1.15rem;
    left: 50%;
    z-index: 3;
    width: 96px;
    height: 24px;
    transform: translateX(-50%);
    border-radius: 999px;
    background: #020617;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .phone-screen {
    position: relative;
    overflow: hidden;
    height: 100%;
    border-radius: 2.25rem;
    background: white;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .phone-screen::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 10rem),
      linear-gradient(90deg, rgba(255, 255, 255, 0.16), transparent 5rem);
  }

  .phone-site {
    --scroll-distance: -38%;
    min-height: 1060px;
    background:
      radial-gradient(circle at top right, rgba(37, 99, 235, 0.18), transparent 14rem),
      linear-gradient(180deg, #ffffff 0%, #fbfcff 58%, #f1eadf 100%);
    animation: phoneScroll 14s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes phoneScroll {
    0%,
    14% {
      transform: translateY(0);
    }

    50%,
    64% {
      transform: translateY(var(--scroll-distance));
    }

    100% {
      transform: translateY(0);
    }
  }

  .phone-hero {
    display: grid;
    gap: 0.75rem;
    padding: 3.8rem 1.05rem 1.2rem;
  }

  .phone-site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .phone-site-nav strong {
    color: var(--text);
    font-size: 0.96rem;
    letter-spacing: -0.03em;
  }

  .phone-site-nav span {
    display: inline-flex;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: var(--blue-soft);
    color: var(--blue-dark);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .phone-eyebrow,
  .phone-section-label {
    color: var(--blue);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    line-height: 1.2;
  }

  .phone-hero h2 {
    font-size: 2.15rem;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .phone-hero p {
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .phone-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .phone-actions span {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0.55rem 0.7rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 750;
  }

  .phone-actions span:first-child {
    background: var(--blue);
    color: white;
  }

  .phone-actions span:last-child {
    background: white;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .phone-section {
    display: grid;
    gap: 0.75rem;
    padding: 1.05rem;
  }

  .phone-mini-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
  }

  .phone-mini-grid div {
    display: grid;
    align-content: end;
    min-height: 128px;
    padding: 0.8rem;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.8);
  }

  .phone-mini-grid span {
    width: 32px;
    height: 32px;
    margin-bottom: 0.65rem;
    border-radius: 0.8rem;
    background: var(--blue-soft);
  }

  .phone-mini-grid p {
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .phone-mini-grid strong {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.15;
  }

  .phone-feature {
    display: grid;
    gap: 0.45rem;
    margin: 0.35rem 1.05rem;
    padding: 1rem;
    border-radius: 1.15rem;
    background: var(--ink);
  }

  .phone-feature p:first-child {
    color: #93c5fd;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    line-height: 1.2;
  }

  .phone-feature h3 {
    color: white;
    font-size: 1.25rem;
    line-height: 1.03;
  }

  .phone-feature p:last-child {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .phone-info-list {
    display: grid;
    gap: 0.65rem;
  }

  .phone-info-list div {
    padding: 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.78);
  }

  .phone-info-list strong {
    display: block;
    color: var(--text);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .phone-info-list p {
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .phone-cta {
    display: grid;
    gap: 0.75rem;
    margin: 0.35rem 1.05rem 1.2rem;
    padding: 1rem;
    border-radius: 1.15rem;
    background: white;
    border: 1px solid rgba(37, 99, 235, 0.16);
    box-shadow: 0 16px 40px rgba(16, 24, 40, 0.08);
  }

  .phone-cta p {
    color: var(--text);
    font-size: 1.1rem;
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .phone-cta span {
    display: inline-flex;
    justify-content: center;
    padding: 0.65rem 0.8rem;
    border-radius: 999px;
    background: var(--blue);
    color: white;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .phone-note {
    width: min(100%, 390px);
    display: grid;
    gap: 0.3rem;
    padding: 1rem 1.1rem;
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(37, 99, 235, 0.12);
    box-shadow: 0 14px 40px rgba(16, 24, 40, 0.08);
  }

  .phone-note strong {
    color: var(--text);
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }

  .phone-note p {
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .builder-strip {
    padding: 0 0 4.5rem;
  }

  .builder-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid rgba(37, 99, 235, 0.14);
    border-radius: 1.35rem;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 18px 48px rgba(16, 24, 40, 0.08);
  }

  .builder-image {
    width: 116px;
    height: 116px;
    overflow: hidden;
    border-radius: 1.35rem;
    background: var(--soft);
    border: 1px solid rgba(37, 99, 235, 0.12);
  }

  .builder-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 62%;
  }

  .builder-copy {
    display: grid;
    gap: 0.35rem;
  }

  .builder-copy h2 {
    max-width: 760px;
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.08;
  }

  .builder-copy p:last-child {
    max-width: 820px;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .builder-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.7rem 0.9rem;
    border-radius: 999px;
    background: var(--blue-soft);
    color: var(--blue-dark);
    font-size: 0.88rem;
    font-weight: 750;
    white-space: nowrap;
  }

  .section {
    padding: 5rem 0;
  }

  .soft {
    background: var(--soft);
  }

  .two-column,
  .contact-grid,
  .faq-grid,
  .fit-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .rich-copy {
    display: grid;
    gap: 1rem;
    max-width: 740px;
  }

  .fit-section {
    background: var(--bg);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .fit-list {
    display: grid;
    gap: 0.85rem;
  }

  .fit-item {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid var(--border);
    border-radius: 1rem;
  }

  .fit-item span {
    width: 10px;
    height: 10px;
    margin-top: 0.45rem;
    border-radius: 999px;
    background: var(--blue);
  }

  .section-head {
    display: grid;
    gap: 0.9rem;
    max-width: 780px;
    margin-bottom: 2rem;
  }

  .price-table {
    border-top: 1px solid var(--border);
  }

  .price-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: start;
    padding: 1.65rem 0;
    border-bottom: 1px solid var(--border);
  }

  .price-row div {
    display: grid;
    gap: 0.35rem;
    max-width: 760px;
  }

  .price {
    color: var(--blue-dark);
    font-weight: 750;
    white-space: nowrap;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .project-card {
    overflow: hidden;
    background: var(--card);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 1.25rem;
    box-shadow: 0 16px 44px rgba(16, 24, 40, 0.06);
  }

  .project-preview-shell {
    background: #f8fafc;
    border-bottom: 1px solid var(--border);
  }

  .project-preview-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0.9rem;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
  }

  .project-preview-top span:first-child {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 750;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .project-preview-top span:last-child {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 999px;
    background: white;
    color: var(--blue-dark);
    font-size: 0.9rem;
    font-weight: 800;
    border: 1px solid rgba(37, 99, 235, 0.12);
  }

  .project-preview {
    height: 315px;
    overflow-y: auto;
    overscroll-behavior: contain;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(241, 245, 249, 0.7)),
      #f8fafc;
  }

  .project-preview:focus {
    outline: 3px solid rgba(37, 99, 235, 0.22);
    outline-offset: -3px;
  }

  .project-preview img {
    width: 100%;
    display: block;
  }

  .project-preview::-webkit-scrollbar {
    width: 0.55rem;
  }

  .project-preview::-webkit-scrollbar-track {
    background: #eef2f7;
  }

  .project-preview::-webkit-scrollbar-thumb {
    background: rgba(37, 99, 235, 0.35);
    border-radius: 999px;
  }

  .project-content {
    display: grid;
    gap: 0.65rem;
    padding: 1.25rem;
  }

  .project-type {
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 750;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .package-match {
    color: var(--blue-dark);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.35rem;
  }

  .project-links a,
  .project-links span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0.5rem 0.7rem;
    border-radius: 999px;
    background: var(--blue-soft);
    color: var(--blue-dark);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .project-links a:hover {
    background: var(--blue);
    color: white;
  }

  .about {
    background: var(--bg);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .portrait-card {
    position: relative;
    overflow: hidden;
    min-height: 540px;
    border-radius: 1.5rem;
    border: 1px solid rgba(37, 99, 235, 0.14);
    background: var(--soft);
    box-shadow: 0 24px 70px rgba(16, 24, 40, 0.1);
  }

  .portrait-card img {
    width: 100%;
    height: 100%;
    min-height: 540px;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .guidance {
    background: var(--ink);
  }

  .guidance h2 {
    color: white;
  }

  .guidance p {
    color: rgba(255, 255, 255, 0.75);
  }

  .guidance .eyebrow {
    color: #93c5fd;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .process-card {
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.55);
  }

  .process-card span {
    display: block;
    margin-bottom: 1rem;
    color: var(--blue);
    font-weight: 750;
    font-size: 0.82rem;
  }

  .process-card h3 {
    margin-bottom: 0.55rem;
  }

  .faq-list {
    display: grid;
    gap: 0.8rem;
  }

  .faq-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1rem 1.1rem;
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--text);
    font-weight: 650;
  }

  .faq-item p {
    margin-top: 0.75rem;
  }

  form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--card);
  }

  label {
    display: grid;
    gap: 0.4rem;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 550;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    padding: 0.85rem 0.95rem;
    background: white;
    color: var(--text);
    font: inherit;
  }

  textarea {
    resize: vertical;
  }

  button {
    cursor: pointer;
  }

  .form-note {
    font-size: 0.9rem;
  }

  .form-status {
    display: none;
    margin-top: -0.2rem;
    padding: 0.85rem 0.95rem;
    border-radius: 0.85rem;
    font-size: 0.92rem;
    font-weight: 650;
    line-height: 1.4;
  }

  .form-status.success {
    display: block;
    background: #dcfce7;
    color: #166534;
    border: 1px solid #86efac;
  }

  .form-status.error {
    display: block;
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  footer p {
    color: var(--text);
    font-weight: 700;
  }

  footer span {
    color: var(--muted);
  }

  @media (max-width: 1000px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .project-preview {
      height: 390px;
    }
  }

  @media (max-width: 900px) {
    nav {
      display: none;
    }

    .mobile-nav-cta {
      display: inline-flex;
    }

    .mobile-section-menu {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      padding-bottom: 0.75rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .mobile-section-menu::-webkit-scrollbar {
      display: none;
    }

    .mobile-section-menu a {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0.52rem 0.72rem;
      border: 1px solid rgba(37, 99, 235, 0.12);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      color: var(--blue-dark);
      font-size: 0.78rem;
      font-weight: 750;
      box-shadow: 0 8px 24px rgba(16, 24, 40, 0.06);
      white-space: nowrap;
    }

    .mobile-section-menu a:hover {
      background: var(--blue-soft);
    }

    .hero-grid,
    .two-column,
    .contact-grid,
    .about-grid,
    .faq-grid,
    .fit-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 4.25rem 0 3rem;
    }

    .phone-showcase {
      max-width: 620px;
      min-height: auto;
      justify-items: start;
    }

    .phone-frame {
      justify-self: center;
    }

    .builder-card {
      grid-template-columns: auto 1fr;
    }

    .builder-link {
      grid-column: 2;
      width: fit-content;
    }

    .process-grid {
      grid-template-columns: 1fr;
    }

    .price-row {
      grid-template-columns: 1fr;
      gap: 0.7rem;
    }

    .portrait-card {
      min-height: 420px;
      max-width: 520px;
    }

    .portrait-card img {
      min-height: 420px;
    }

    .footer-inner {
      display: grid;
    }
  }

  @media (max-width: 600px) {
    .container {
      width: min(100% - 1.25rem, 1120px);
    }

    .nav-wrap {
      min-height: 64px;
    }

    .brand {
      font-size: 0.95rem;
    }

    .mobile-nav-cta {
      min-height: 36px;
      padding: 0.6rem 0.78rem;
      font-size: 0.82rem;
    }

    .mobile-section-menu {
      gap: 0.45rem;
      padding-bottom: 0.65rem;
    }

    .mobile-section-menu a {
      min-height: 32px;
      padding: 0.5rem 0.68rem;
      font-size: 0.76rem;
    }

    h1 {
      font-size: clamp(2.35rem, 12vw, 3.4rem);
    }

    h2 {
      font-size: clamp(1.85rem, 9vw, 2.8rem);
    }

    .section {
      padding: 4rem 0;
    }

    .phone-showcase {
      justify-items: center;
    }

    .phone-frame {
