const process = [
  {
    step: "01",
    title: "Understand the business",
    text: "We start by learning what you offer, who your customers are, what feels confusing, and what your site needs to help people do.",
  },
  {
    step: "02",
    title: "Organize the experience",
    text: "We map out the pages, products, services, forms, navigation, and customer flow so the site has a clear structure before it is built.",
  },
  {
    step: "03",
    title: "Build and refine",
    text: "We design the site, write and organize the content, clean up the details, and test the experience across key pages and screens.",
  },
  {
    step: "04",
