    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sitesbychristian.com/" />
    <meta property="og:title" content="Sites by Christian" />
    <meta
      property="og:description"
      content="Custom websites, ecommerce systems, and practical website support for small businesses."
    />
    <meta
      property="og:image"
      content="https://sitesbychristian.com/images/sites-by-christian-preview.png"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Sites by Christian" />
    <meta
      name="twitter:description"
      content="Custom websites, ecommerce systems, and practical website support for small businesses."
    />
    <meta
      name="twitter:image"
      content="https://sitesbychristian.com/images/sites-by-christian-preview.png"
    />
  </head>

  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a href="#" class="brand">Sites by Christian</a>

        <nav>
          <a href="#services-work">Services</a>
          <a href="#pricing">Support</a>
          <a href="#about">About</a>
          <a href="#process">Process</a>
          <a href="#faq">FAQ</a>
          <a href="#contact" class="nav-cta">Start a project</a>
        </nav>

        <a href="#contact" class="mobile-nav-cta">Start a project</a>
      </div>

      <div class="container mobile-section-menu" aria-label="Mobile section navigation">
        <a href="#services-work">Services</a>
        <a href="#pricing">Support</a>
        <a href="#about">About</a>
        <a href="#process">Process</a>
        <a href="#faq">FAQ</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Custom websites & ecommerce systems</p>

            <h1>Websites that look polished, work clearly, and make business easier.</h1>

            <p class="lead">
              We build entry sites, custom websites, and ecommerce systems for small businesses
              that need a cleaner online presence, a smoother customer experience, and a setup
              they can actually manage.
            </p>

            <div class="hero-actions">
              <a href="#contact" class="button primary">Start a project</a>
              <a href="#services-work" class="button secondary">View services</a>
            </div>

            <div class="trust-row">
              <span>Entry sites</span>
              <span>Custom builds</span>
              <span>Ecommerce systems</span>
              <span>Monthly support</span>
            </div>
          </div>

          <div class="phone-showcase" aria-label="Animated mobile website preview">
            <div class="phone-frame">
              <div class="phone-speaker"></div>

              <div class="phone-screen">
                <div class="phone-site">
                  <section class="phone-hero">
                    <div class="phone-site-nav">
                      <strong>Your Business</strong>
                      <span>Menu</span>
                    </div>

                    <p class="phone-eyebrow">Small business website</p>
                    <h2>A clear online home for what you do.</h2>
                    <p>
                      Present your services, products, story, and next steps in a way customers can
                      understand quickly.
                    </p>

                    <div class="phone-actions">
                      <span>Start here</span>
                      <span>View services</span>
                    </div>
                  </section>

                  <section class="phone-section">
                    <p class="phone-section-label">What customers need</p>

                    <div class="phone-mini-grid">
                      <div>
                        <span></span>
                        <p>Services</p>
                        <strong>Clear options</strong>
                      </div>

                      <div>
                        <span></span>
                        <p>Products</p>
                        <strong>Easy to browse</strong>
                      </div>
                    </div>
                  </section>

                  <section class="phone-feature">
                    <p>Built around your business</p>
                    <h3>Not just a template with your logo on it.</h3>
                    <p>
                      Pages, content, forms, products, and customer flow are organized around what
                      your business actually needs.
                    </p>
                  </section>

                  <section class="phone-section">
                    <p class="phone-section-label">Simple details</p>

                    <div class="phone-info-list">
                      <div>
                        <strong>Customer info</strong>
                        <p>Hours, pickup details, FAQs, ordering steps, or service notes.</p>
                      </div>

                      <div>
                        <strong>Better inquiries</strong>
                        <p>Clear contact forms that help customers know what to send.</p>
                      </div>

                      <div>
                        <strong>Easy updates</strong>
                        <p>Guidance so your site does not feel confusing after launch.</p>
                      </div>
                    </div>
                  </section>

                  <section class="phone-cta">
                    <p>Ready for a site that feels more professional?</p>
                    <span>Send inquiry</span>
                  </section>
